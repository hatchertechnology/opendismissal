# SECURITY WARNING: This is an EXAMPLE file only
# DO NOT commit actual secrets to version control
# 
# To create real secrets:
# 1. Copy this file to secret.yaml (which is gitignored)
# 2. Generate secure random values for all secrets
# 3. Apply to cluster with: kubectl apply -f secret.yaml
#
# Generate secure values:
# - Django Secret Key: python -c "import secrets; print(secrets.token_urlsafe(50))"
# - Database Password: openssl rand -base64 32
# - Admin Password: openssl rand -base64 24
#
apiVersion: v1
kind: Secret
metadata:
  name: django-secrets
  namespace: opendismissal-demo
  labels:
    app.kubernetes.io/name: opendismissal
    app.kubernetes.io/component: secret
type: Opaque
stringData:  # Use stringData for clarity - Kubernetes will base64 encode automatically
  # Django secret key - MUST be changed for production
  SECRET_KEY: "CHANGE-ME-generate-with-python-secrets-module"
  
  # PostgreSQL password - MUST be changed for production
  POSTGRES_PASSWORD: "CHANGE-ME-generate-with-openssl-rand"
  
  # Cloudflare API token for ExternalDNS - obtain from Cloudflare dashboard
  CLOUDFLARE_API_TOKEN: "CHANGE-ME-get-from-cloudflare-dashboard"
  
  # Django superuser - create after deployment with manage.py createsuperuser
  # These are only used for initial setup and should be changed immediately
  DJANGO_SUPERUSER_USERNAME: "CHANGE-ME-do-not-use-admin"
  DJANGO_SUPERUSER_PASSWORD: "CHANGE-ME-generate-secure-password"
  DJANGO_SUPERUSER_EMAIL: "CHANGE-ME-your-email@example.com"
  
  # Database URL with SSL required
  # Format: postgresql://username:password@host:port/dbname?sslmode=require
  DATABASE_URL: "postgresql://django_user:CHANGE-ME-POSTGRES-PASSWORD@postgresql-service:5432/opendismissal?sslmode=require"